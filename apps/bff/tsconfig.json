{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "rootDir": "../../",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*", "./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "app",
    "src",
    "../../packages/contracts/src",
    "../../packages/contracts/http",
    "../../packages/policies/src",
    "../../packages/services/src",
    "../../packages/posting-rules/src",
    "../../packages/ports/src",
    "../../packages/adapters/db/src",
    "../../packages/utils/src"
  ],
  "exclude": ["node_modules"]
}

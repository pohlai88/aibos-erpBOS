{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*", "./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "app",
    "src"
  ],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/contracts" },
    { "path": "../../packages/policies" },
    { "path": "../../packages/services" },
    { "path": "../../packages/posting-rules" },
    { "path": "../../packages/ports" },
    { "path": "../../packages/adapters/db" },
    { "path": "../../packages/utils" }
  ]
}

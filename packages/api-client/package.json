{
  "name": "@aibos/api-client",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "tsc -b",
    "build:js": "tsup",
    "build": "pnpm run build:types && pnpm run build:js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "echo 'API client - no dev server needed'",
    "gen:types": "openapi-typescript ../contracts/openapi/openapi.json -o src/types.gen.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo 'No tests configured for api-client'",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "24.6.0"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}
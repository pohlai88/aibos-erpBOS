{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../contracts" },
    { "path": "../ports" },
    { "path": "../posting-rules" },
    { "path": "../policies" },
    { "path": "../adapters/db" },
    { "path": "../utils" }
  ]
}

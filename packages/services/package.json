{
  "name": "@aibos/services",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "echo 'Services - no dev server needed'",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests configured for services'"
  },
  "dependencies": {
    "@aibos/contracts": "workspace:*",
    "@aibos/db-adapter": "workspace:*",
    "@aibos/policies": "workspace:*",
    "@aibos/ports": "workspace:*",
    "@aibos/posting-rules": "workspace:*",
    "@aibos/utils": "workspace:*"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}
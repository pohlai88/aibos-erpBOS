{
  "name": "@aibos/services",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./src/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "default": "./dist/*.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "tsc -b",
    "build:js": "tsup",
    "build": "pnpm run build:types && pnpm run build:js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "echo 'Services - no dev server needed'",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo 'No tests configured for services'",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aibos/contracts": "workspace:*",
    "@aibos/db-adapter": "workspace:*",
    "@aibos/policies": "workspace:*",
    "@aibos/ports": "workspace:*",
    "@aibos/posting-rules": "workspace:*",
    "@aibos/utils": "workspace:*"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}
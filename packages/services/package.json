{
  "name": "@aibos/services",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "clean": "rimraf dist",
    "build:types": "tsc -b",
    "build:js": "tsup",
    "build": "pnpm run build:types && pnpm run build:js"
  },
  "dependencies": {
    "@aibos/contracts": "workspace:*",
    "@aibos/db-adapter": "workspace:*",
    "@aibos/policies": "workspace:*",
    "@aibos/ports": "workspace:*",
    "@aibos/posting-rules": "workspace:*",
    "@aibos/utils": "workspace:*"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}
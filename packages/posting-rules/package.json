{
  "name": "@aibos/posting-rules",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "echo 'Posting rules - no dev server needed'",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests configured for posting-rules'"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "24.6.0"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}
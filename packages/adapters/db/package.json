{
  "name": "@aibos/db-adapter",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.mjs",
      "require": "./dist/schema.cjs",
      "default": "./dist/schema.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "echo 'DB adapter - no dev server needed'",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "seed": "tsx src/seed.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo 'No tests configured for db-adapter'"
  },
  "dependencies": {
    "@aibos/ports": "workspace:*",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6"
  },
  "turbo": {
    "pipeline": {
      "build": "build#lib"
    }
  }
}